{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "./",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler"
  },
  "include": ["*.ts", "api/api.ts", "chess/chess.ts", "pong/**/*.ts", "auth/auth-session.ts", "auth/auth-validation.ts", "auth/fetch-auth-guard.ts", "login/login.ts", "register/register.ts", "privacy/privacy.ts", "terms/terms.ts", "i18n/**/*.ts"],
  "exclude": ["node_modules"]
}
